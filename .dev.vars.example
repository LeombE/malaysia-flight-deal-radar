# Phase 5.5 local demo placeholders only. Leave secrets blank unless testing locally.

# Optional Amadeus fallback provider. Leave blank to keep disabled.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CURRENCY_CODE=MYR
AMADEUS_RETENTION_MODE=NO_CACHE
AMADEUS_MAX_RETRY_ATTEMPTS=3
AMADEUS_RETRY_BASE_DELAY_MS=250
AMADEUS_RETRY_MAX_DELAY_MS=2000
AMADEUS_MIN_REQUEST_INTERVAL_MS=100
AMADEUS_MAX_CONCURRENCY=1

# Optional Duffel provider. Leave token blank to keep disabled.
DUFFEL_ACCESS_TOKEN=
DUFFEL_API_BASE_URL=https://api.duffel.com
DUFFEL_API_VERSION=v2
DUFFEL_CURRENCY_CODE=MYR
DUFFEL_RETENTION_MODE=NO_CACHE
DUFFEL_TIMEOUT_MS=10000
DUFFEL_RETRY_LIMIT=2
DUFFEL_SMOKE_PROFILE=
DUFFEL_SMOKE_ORIGIN=
DUFFEL_SMOKE_DESTINATION=
DUFFEL_SMOKE_DEPARTURE_DATE=
DUFFEL_SMOKE_RETURN_DATE=
DUFFEL_SMOKE_CABIN_CLASS=economy
DUFFEL_SMOKE_ADULTS=1
DUFFEL_SMOKE_CURRENCY=MYR

# Phase 6A real-provider safety guardrails. Keep disabled for local demo.
ENABLE_REAL_PROVIDERS=false
REAL_PROVIDER_DRY_RUN=true
DEFAULT_REAL_PROVIDER=
MAX_REAL_PROVIDER_SEARCHES_PER_RUN=1
MAX_REAL_PROVIDER_DAILY_BUDGET=1
REAL_PROVIDER_TIMEOUT_MS=10000
REAL_PROVIDER_RETRY_LIMIT=2
REVALIDATE_BEFORE_DISPLAY_MINUTES=15

# Phase 8B/8C cached fare provider. Leave token blank and dry-run enabled by default.
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_API_BASE_URL=https://api.travelpayouts.com
TRAVELPAYOUTS_CURRENCY=MYR
TRAVELPAYOUTS_RETENTION_MODE=AGGREGATE_ONLY
TRAVELPAYOUTS_TIMEOUT_MS=10000
TRAVELPAYOUTS_RETRY_LIMIT=1
TRAVELPAYOUTS_SMOKE_ORIGIN=KUL
TRAVELPAYOUTS_SMOKE_DESTINATION=TPE
TRAVELPAYOUTS_SMOKE_DEPARTURE_AT=
TRAVELPAYOUTS_SMOKE_DEPART_DATE=
TRAVELPAYOUTS_SMOKE_DEPARTURE_DATE=
TRAVELPAYOUTS_SMOKE_RETURN_DATE=
TRAVELPAYOUTS_SMOKE_TRIP_DURATION=5
TRAVELPAYOUTS_SMOKE_ENDPOINT=v2/prices/latest
TRAVELPAYOUTS_SMOKE_CURRENCY=MYR
TRAVELPAYOUTS_SMOKE_LIMIT=5
ENABLE_CACHED_FARE_PROVIDER=false
CACHED_PROVIDER_DRY_RUN=true
DEFAULT_CACHED_PROVIDER=travelpayouts

# Local scheduler/demo limits.
MAX_SEARCHES_PER_CRON_RUN=50
MAX_PROVIDER_CONCURRENCY=3
PROVIDER_DAILY_BUDGET=50
REVALIDATE_BEFORE_ALERT_MINUTES=30
DEFAULT_STAY_LENGTH_DAYS=5
DEFAULT_DEPARTURE_OFFSET_DAYS=45
PROVIDER_FAILURE_DEGRADE_THRESHOLD=3

# Admin endpoints. Leave blank to disable POST /api/admin/scan and POST /api/admin/revalidate.
ADMIN_TOKEN=

# Phase 4 Telegram alerts. Leave token/chat blank to disable sending safely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DRY_RUN=true
TELEGRAM_TIMEOUT_MS=5000
TELEGRAM_MAX_RETRY_ATTEMPTS=3
TELEGRAM_RETRY_BASE_DELAY_MS=250
ALERT_COOLDOWN_HOURS=24
